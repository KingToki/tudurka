# VoiceTasks — настройка окружения
# Скопируй этот файл как .env и заполни значения

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Ключ Claude API от console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# URL где будет хоститься index.html (например Vercel, GitHub Pages, Netlify)
MINI_APP_URL=https://yourdomain.com/voicetasks
